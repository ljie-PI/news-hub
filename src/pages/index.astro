---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const digests = (await getCollection('digest')).sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 5);
const deepDives = (await getCollection('deep-dive')).sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 5);

function tagClass(source: string) {
  const map: Record<string, string> = { HN: 'tag-hn', Reddit: 'tag-reddit', GitHub: 'tag-github', PH: 'tag-ph' };
  return map[source] || '';
}
---
<Base title="News Hub">
  <div class="home-grid">
    <div class="section-card">
      <h2>📋 <a href="/digest">Digest — 每日简报</a></h2>
      <p style="font-size:0.85rem;color:var(--muted);margin-bottom:0.75rem;">GitHub / HN / Reddit / PH 平台日报</p>
      {digests.map(d => (
        <div class="preview-item">
          <span class={`tag ${tagClass(d.data.source)}`}>{d.data.source}</span>
          <a href={`/digest/${d.data.slug}`}> {d.data.title}</a>
        </div>
      ))}
      <a class="more" href="/digest">查看全部 →</a>
    </div>
    <div class="section-card">
      <h2>🔬 <a href="/deep-dive">Deep Dive — 深度调研</a></h2>
      <p style="font-size:0.85rem;color:var(--muted);margin-bottom:0.75rem;">热门话题的深度分析</p>
      {deepDives.map(d => (
        <div class="preview-item">
          <span class={`tag ${tagClass(d.data.source)}`}>{d.data.source}</span>
          <a href={`/deep-dive/${d.data.slug}`}> {d.data.title}</a>
        </div>
      ))}
      <a class="more" href="/deep-dive">查看全部 →</a>
    </div>
  </div>
</Base>
