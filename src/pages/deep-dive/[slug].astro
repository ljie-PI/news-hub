---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('deep-dive');
  return articles.map(article => ({
    params: { slug: article.data.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

function tagClass(source: string) {
  const map: Record<string, string> = { HN: 'tag-hn', Reddit: 'tag-reddit', GitHub: 'tag-github', PH: 'tag-ph' };
  return map[source] || '';
}
---
<Base title={article.data.title}>
  <a class="back" href="/deep-dive">← 返回 Deep Dive</a>
  <div class="article-meta" style="margin-bottom:1rem;">
    <span class={`tag ${tagClass(article.data.source)}`}>{article.data.source}</span>
    <span>{article.data.generated || article.data.date}</span>
  </div>
  <article class="prose">
    <Content />
  </article>
</Base>
